---
import config from "virtual:lightnet/sveltiaAdminConfig"

import { pathWithBase } from "./utils/path-with-base"
---

<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <title>LightNet Administration</title>
    <link
      href={pathWithBase(`/${config.path}/config.json`)}
      type="application/json"
      rel="cms-config-url"
    />
  </head>
  <body>
    <script>
      import { init } from "@sveltia/cms"
      init({})
      window.localStorage.setItem(
        "ln.adminPaths",
        JSON.stringify({
          rootPath: window.location.pathname,
          mediaItemPath:
            window.location.pathname +
            "#/collections/media/entries/{{mediaId}}",
        }),
      )
    </script>
  </body>
</html>
