---
import config from "virtual:lightnet/sveltiaAdminConfig"

const basePath = import.meta.env.BASE_URL.replace(/\/+$/, "")
const adminConfigUrl = `${basePath}/${config.path}/config.json`
---

<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <title>LightNet Administration</title>
    <link href={adminConfigUrl} type="application/json" rel="cms-config-url" />
  </head>
  <body>
    <script>
      import { init } from "@sveltia/cms"
      init({})
    </script>
  </body>
</html>
