---
import config from "virtual:lightnet/config"

import IconExternalLink from "~icons/mdi/external-link.jsx"
import IconMagnify from "~icons/mdi/magnify.jsx"
import IconMenu from "~icons/mdi/menu.jsx"

import { localizePath, searchPagePath } from "../../utils/paths"
import { isExternalUrl } from "../../utils/urls"
import LanguagePicker from "./LanguagePicker.astro"
import Menu from "./Menu.astro"
import MenuItem from "./MenuItem.astro"

const currentPath = Astro.url.pathname
const { t, currentLocale } = Astro.locals.i18n

const items = (config.mainMenu ?? []).map(({ href, label, requiresLocale }) => {
  const isExternal = isExternalUrl(href)
  const path =
    isExternal || !requiresLocale ? href : localizePath(currentLocale, href)
  const isActive =
    !isExternal &&
    (currentPath === localizePath(currentLocale, href) ||
      currentPath === localizePath(currentLocale, `${href}/`) ||
      currentPath === href)
  return {
    path,
    isExternal,
    label,
    isActive,
  }
})
---

<nav class="-me-3 flex items-center">
  {
    !config.searchPage?.hideHeaderSearchIcon && (
      <a
        class="flex p-3 text-gray-600 hover:text-primary"
        aria-label={t("ln.search.title")}
        data-astro-prefetch="viewport"
        href={searchPagePath(currentLocale)}
      >
        <IconMagnify className="h-6 w-6" aria-hidden="true" />
      </a>
    )
  }

  <LanguagePicker />

  {
    !!items.length && (
      <Menu label="ln.header.open-main-menu">
        <IconMenu slot="icon" className="h-6 w-6" aria-hidden="true" />
        {items.map(({ label, path, isActive, isExternal }) => (
          <MenuItem
            href={path}
            active={isActive}
            target={isExternal ? "_blank" : "_self"}
          >
            {t(label)}
            {isExternal && (
              <IconExternalLink
                className="h-4 w-4 shrink-0"
                aria-hidden="true"
              />
            )}
          </MenuItem>
        ))}
      </Menu>
    )
  }
</nav>
