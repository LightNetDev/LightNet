---
import {
  ExternalLinkIcon,
  MenuIcon,
  SearchIcon,
  SquarePenIcon,
} from "lucide-react"
import config from "virtual:lightnet/config"

import { isExternalUrl } from "../../../utils/is-external-url"
import { localizePath, searchPagePath } from "../../../utils/paths"
import LanguageSelectionMenu from "./LanguageSelectionMenu.astro"
import Menu from "./Menu.astro"
import MenuItem from "./MenuItem.astro"

const currentPath = Astro.url.pathname
const { t, tConfigField, currentLocale } = Astro.locals.i18n

const items = (config.mainMenu ?? []).map(({ href, label, requiresLocale }) => {
  const isExternal = isExternalUrl(href)
  const isActive =
    currentPath === localizePath(currentLocale, href) ||
    currentPath === localizePath(currentLocale, `${href}/`) ||
    currentPath === href
  return {
    href: requiresLocale ? localizePath(currentLocale, href) : href,
    labelText: tConfigField(label, config),
    isActive,
    isExternal,
  }
})
---

<nav class="-me-3 flex items-center">
  <a
    class="hidden p-3 text-gray-600 hover:text-primary"
    aria-label={t("ln.details.edit")}
    href="#"
    id="header-admin-btn"
  >
    <SquarePenIcon />
  </a>
  {
    !config.searchPage?.hideHeaderSearchIcon && (
      <a
        class="flex p-3 text-gray-600 hover:text-primary"
        aria-label={t("ln.search.title")}
        data-astro-prefetch="viewport"
        href={searchPagePath(currentLocale)}
      >
        <SearchIcon />
      </a>
    )
  }

  <LanguageSelectionMenu />

  {
    !!items.length && (
      <Menu label="ln.header.open-main-menu">
        <MenuIcon slot="icon" />
        {items.map(({ labelText, href, isActive, isExternal }) => (
          <MenuItem href={href} active={isActive}>
            {labelText}
            {isExternal && (
              <ExternalLinkIcon
                size="1.2rem"
                className="shrink-0 rtl:scale-x-[-1]"
              />
            )}
          </MenuItem>
        ))}
      </Menu>
    )
  }
</nav>
<script>
  const initAdminButton = () => {
    const adminPath = localStorage.getItem("ln.adminPaths")
    if (!adminPath) {
      return
    }
    const rootPath = JSON.parse(adminPath).rootPath as string | undefined
    const btn: HTMLAnchorElement | null =
      document.querySelector("#header-admin-btn")

    if (!rootPath || !btn) {
      return
    }
    btn.href = rootPath
    btn.classList.remove("hidden")
    btn.classList.add("flex")
  }
  initAdminButton()
</script>
