---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"
import config from "virtual:lightnet/config"
import logo from "virtual:lightnet/logo"

import { localizePath } from "../../utils/paths"

function getWidth(logo: ImageMetadata) {
  const size = config.logo?.size ?? 28
  // Calculate width to use for the logo.
  // This based on the size that should measure the shorter side
  // of the image
  return Math.floor(size * Math.max(1, logo.width / logo.height))
}

const { currentLocale, tInline } = Astro.locals.i18n

const logoAlt = (() => {
  if (config.logo?.alt) {
    return tInline(config.logo.alt, {
      path: ["config", "logo", "alt"],
    })
  }
  if (config.logo?.replacesTitle) {
    return tInline(config.title, {
      path: ["config", "title"],
    })
  }
  return ""
})()
---

<a
  class="flex items-center gap-3 font-bold text-gray-600 md:text-lg"
  href={localizePath(currentLocale, "/")}
>
  {
    logo &&
      (logo.format === "svg" ? (
        <img
          src={logo.src}
          alt={logoAlt}
          style={`width:${getWidth(logo)}px;`}
        />
      ) : (
        <Image
          src={logo}
          alt={logoAlt}
          style={`width:${getWidth(logo)}px;`}
          width={getWidth(logo)}
          densities={[1.5, 2, 3]}
          loading="eager"
        />
      ))
  }{
    !config.logo?.replacesTitle &&
      tInline(config.title, {
        path: ["config", "title"],
      })
  }</a
>
