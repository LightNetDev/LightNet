---
import { GlobeIcon } from "lucide-react"

import { resolveTranslatedLanguage } from "../../i18n/resolve-language"
import { localizePath } from "../../utils/paths"
import Menu from "./Menu.astro"
import MenuItem from "./MenuItem.astro"

const { t, locales, currentLocale } = Astro.locals.i18n

const normalizedBase =
  import.meta.env.BASE_URL !== "/"
    ? import.meta.env.BASE_URL.replace(/\/+$/, "")
    : ""
const pathnameWithoutBase =
  normalizedBase &&
  (Astro.url.pathname === normalizedBase ||
    Astro.url.pathname.startsWith(`${normalizedBase}/`))
    ? Astro.url.pathname.slice(normalizedBase.length) || "/"
    : Astro.url.pathname
const hasLocale =
  currentLocale &&
  (pathnameWithoutBase.startsWith(`/${currentLocale}/`) ||
    pathnameWithoutBase === `/${currentLocale}`)

const translations = (
  await Promise.all(
    locales.map(async (locale) => ({
      locale,
      label: resolveTranslatedLanguage(locale, t).labelText,
      active: locale === currentLocale,
      href: currentPathWithLocale(locale),
    })),
  )
).sort((a, b) => a.label.localeCompare(b.label))

function currentPathWithLocale(locale: string) {
  const currentPathWithoutLocale = hasLocale
    ? pathnameWithoutBase.slice(currentLocale.length + 1)
    : pathnameWithoutBase
  return localizePath(locale, currentPathWithoutLocale)
}

const disabled = !hasLocale && pathnameWithoutBase !== "/"
---

{
  translations.length > 1 && (
    <Menu disabled={disabled} label="ln.header.select-language">
      <GlobeIcon slot="icon" />
      {translations.map(({ label, locale, active, href }) => (
        <MenuItem href={href} hreflang={locale} active={active}>
          {label}
        </MenuItem>
      ))}
    </Menu>
  )
}
