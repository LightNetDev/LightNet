---
import { GlobeIcon } from "lucide-react"

import { getLanguageLinks } from "../../i18n/get-language-links"
import Menu from "./Menu.astro"
import MenuItem from "./MenuItem.astro"

const { locales, currentLocale, tConfigField } = Astro.locals.i18n

// Reuse the shared locale-link helper so header and footer stay in sync.
const {
  currentPath,
  hasLocale,
  links: translations,
} = getLanguageLinks({
  currentLocale,
  locales,
  pathname: Astro.url.pathname,
  tConfigField,
})

// Disable the menu on pages that are not routed by locale, except the home page.
const disabled = !hasLocale && currentPath !== "/"
---

{
  // Only render the menu when there is more than one site language.
  translations.length > 1 && (
    <Menu disabled={disabled} label="ln.header.select-language">
      {/* Use the globe icon as a lightweight visual hint for language switching. */}
      <GlobeIcon slot="icon" />
      {/* Render one navigation item per available site locale. */}
      {translations.map(({ label, locale, active, href }) => (
        <MenuItem href={href} hreflang={locale} active={active}>
          {label}
        </MenuItem>
      ))}
    </Menu>
  )
}
