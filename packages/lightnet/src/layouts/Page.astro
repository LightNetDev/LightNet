---
import "./global.css"

import CustomFooter from "virtual:lightnet/components/CustomFooter"
import CustomHead from "virtual:lightnet/components/CustomHead"
import config from "virtual:lightnet/config"

import { resolveLanguage } from "../i18n/resolve-language"
import { pathWithBase } from "../utils/paths"
import Favicon from "./components/Favicon.astro"
import Footer from "./components/Footer.astro"
import Header from "./components/Header.astro"
import ViewTransition from "./components/ViewTransition.astro"

export interface Props {
  /**
   * Title of the page to be shown in browser tab.
   */
  title?: string
  /**
   * Meta description for the page.
   */
  description?: string
  /**
   * Css classes to apply to main element.
   */
  mainClass?: string
  /**
   * Locale to override current locale from path.
   */
  locale?: string
  /**
   * Disables the `should-track` attribute on the root `html` element for
   * pages that should be excluded from analytics tracking.
   *
   * The `should-track`` attribute does not enable tracking on its own; it is intended to be picked up by
   * analytics providers that choose to respect it. e.g. @lightnet/plausible-analytics
   */
  disableShouldTrack?: boolean
}

const { title, description, mainClass, locale, disableShouldTrack } =
  Astro.props
const { currentLocale: pathCurrentLocale, tConfigField } = Astro.locals.i18n
const currentLocale = locale ?? pathCurrentLocale
const configTitle = tConfigField(config.title, config)
const { direction } = resolveLanguage(currentLocale)
---

<!doctype html>
<html
  lang={currentLocale}
  dir={direction}
  data-should-track={disableShouldTrack ? undefined : true}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {CustomHead && <CustomHead />}
    <title>{title ? `${title} | ${configTitle}` : configTitle}</title>
    {description && <meta name="description" content={description} />}
    {config.manifest && <link rel="manifest" href={config.manifest} />}
    <link rel="prefetch" href={pathWithBase("/api/internal/search.json")} />
    <Favicon />
    <ViewTransition />
  </head>
  <body
    class="flex min-h-screen flex-col overflow-y-scroll bg-gray-50 text-gray-900"
  >
    <Header />
    <main class={`grow pb-8 pt-14 sm:py-20 ${mainClass ?? ""}`}>
      <slot />
    </main>
    {CustomFooter ? <CustomFooter /> : <Footer />}
  </body>
</html>
