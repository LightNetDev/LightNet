---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { getTranslatedMediaTypes } from "../content/get-media-types"
import { detailsPagePath } from "../utils/paths"
import CarouselSection from "./CarouselSection.astro"
import CoverImageDecorator from "./CoverImageDecorator"
import Icon from "./Icon"
import Section, { type Props as SectionProps } from "./Section.astro"

type MediaItem = {
  id: string
  data: {
    title: string
    type: { id: string }
    image: ImageMetadata
  }
}

type Props = Omit<SectionProps, "maxWidth"> & {
  items: (MediaItem | undefined)[]
  itemWidth?: "infer" | "narrow" | "wide"
  layout?: "grid" | "carousel"
}

const {
  items: itemsInput,
  itemWidth = "infer",
  layout = "carousel",
  ...sectionProps
} = Astro.props

const { currentLocale, tContentField } = Astro.locals.i18n

const types = Object.fromEntries(
  (await getTranslatedMediaTypes(currentLocale, tContentField)).map((type) => [
    type.id,
    type,
  ]),
)

// We allow for undefined values because
// this is in the return type of getEntry
const items = itemsInput.filter((item) => !!item)

const { landscapeCount, portraitCount } = items.slice(0, 10).reduce(
  (acc, item) => {
    const { width, height } = item.data.image
    if (width > height) {
      acc.landscapeCount += 1
    }
    if (height > width) {
      acc.portraitCount += 1
    }
    return acc
  },
  { landscapeCount: 0, portraitCount: 0 },
)

const resolvedItemWidth =
  itemWidth === "infer"
    ? landscapeCount > portraitCount
      ? "wide"
      : "narrow"
    : itemWidth

const imageSizes = {
  narrow:
    // 2 columns
    "(max-width: 640px) calc(calc(100vw - 3rem ) / 2), " +
    // 3 columns
    "(max-width: 768px) calc(calc(100vw - 4rem ) / 3), " +
    // 4 columns
    "(max-width: 1024px) calc(calc(100vw - 10rem ) / 4), " +
    // 5 columns
    "(max-width: 1280px) calc(calc(100vw - 12rem ) / 5), " +
    // 5 columns - full size
    "217px",
  wide:
    // 1 column
    "(max-width: 640px) calc(calc(100vw - 2rem ) / 1), " +
    // 2 columns
    "(max-width: 768px) calc(calc(100vw - 3rem ) / 2), " +
    // 3 columns
    "(max-width: 1024px) calc(calc(100vw - 8rem ) / 3), " +
    // 4 columns
    "(max-width: 1280px) calc(calc(100vw - 10rem ) / 4), " +
    // 5 columns - full size
    "280px",
} as const

const gridLayouts = {
  narrow: "grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5",
  wide: "grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4",
} as const
---

{
  layout === "grid" && (
    <Section {...sectionProps}>
      <ol
        class="grid items-end justify-between gap-4 md:gap-8"
        class:list={gridLayouts[resolvedItemWidth]}
      >
        {items.map((item) => {
          const coverImageStyle = types[item.data.type.id].coverImageStyle
          return (
            <li>
              <a
                href={detailsPagePath(currentLocale, item)}
                class="group flex flex-col gap-3"
              >
                <CoverImageDecorator
                  style={coverImageStyle}
                  className="outline-2 outline-gray-400 transition-all duration-75 ease-in-out sm:group-hover:outline"
                >
                  <Image
                    class="h-full w-full object-cover"
                    class:list={[
                      coverImageStyle === "video" && "absolute top-0",
                    ]}
                    src={item.data.image}
                    alt=""
                    widths={[128, 256, 512, 768]}
                    sizes={imageSizes[resolvedItemWidth]}
                  />
                </CoverImageDecorator>

                <span class="line-clamp-2 h-12 text-balance text-sm font-bold text-gray-700">
                  <Icon
                    className={`${types[item.data.type.id].icon} me-2 align-bottom`}
                    ariaLabel={types[item.data.type.id].labelText}
                  />
                  {item.data.title}
                </span>
              </a>
            </li>
          )
        })}
      </ol>
    </Section>
  )
}
{
  layout === "carousel" && (
    <CarouselSection {...sectionProps}>
      {items.map((item) => {
        const coverImageStyle = types[item.data.type.id].coverImageStyle
        return (
          <li
            class={`carousel-item--${resolvedItemWidth} h-full`}
            role="group"
            aria-roledescription="slide"
          >
            <a
              href={detailsPagePath(currentLocale, item)}
              class="group flex h-full flex-col justify-end gap-3"
            >
              <CoverImageDecorator
                style={coverImageStyle}
                className="outline-2 outline-gray-400 transition-all duration-75 ease-in-out sm:group-hover:outline"
              >
                <Image
                  class="h-full w-full object-cover"
                  src={item.data.image}
                  alt=""
                  widths={[128, 256, 512, 768]}
                  sizes={imageSizes[resolvedItemWidth]}
                />
              </CoverImageDecorator>

              <span class="line-clamp-2 h-12 text-balance text-sm font-bold text-gray-700">
                <Icon
                  className={`${types[item.data.type.id].icon} me-2 align-bottom`}
                  ariaLabel={types[item.data.type.id].labelText}
                />
                {item.data.title}
              </span>
            </a>
          </li>
        )
      })}
    </CarouselSection>
  )
}
